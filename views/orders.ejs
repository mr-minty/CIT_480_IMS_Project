<!DOCTYPE html>
<html lang="en">
    <!--EJS vars: %title, %content, %user-->
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Favicon -->
    <link rel="icon" href="img/stockify-favicon-32x32.png" type="image/x-icon">

   <!-- Bootstrap call -->
    <%- include("partials/bootstrap-call.ejs") %>
    <%- include("partials/fonts-call.ejs") %> 

    <!-- CSS call -->
    <link rel="stylesheet" href="/css/orders.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <title><%= title %></title>
</head>

<body>
    <%- include('partials/header') %> 

    <main class="flex-grow-1">
        <div class="container mt-2">
            
             <!-- Header row (separate) -->
            <div class="row">
                <div class="col-12">
                <span class="h1">Orders</span>
                <hr class="w-100">
                </div>
            </div>

            <div class="card">
                <div class="container" id="orderList">
                    <% orders.forEach(({ order_id, status, user_id, created_at, items }) => { %>
                    <div class="order-card">
                        <div class="order-row">
                            <span class="order-row-number">ORD-<%= String(order_id).padStart(4, "0") %></span>
                            <div class="order-row-wrapper">
                                <span class="order-row-status"><%= status %></span>
                                <span class="order-row-dropdown"><i class="fa fa-caret-down"></i></span>
                            </div>
                        </div>
                        <div class="expanded-order-row">
                            
                             <!-- ORDER-DETAILS HEADER-->
                            <div class="order-header-left">Details</div>
                            
                            <!-- ORDER-DETAILS LIST CONTAINER-->
                            <div class="order-details-container">

                                <div class="order-details-list">
                                    <div class="order-details-list-row">  
                                        <span>Assigned To: </span>
                                        <span><%=  user_id || " N/A"%></span>
                                    </div>
                                    <div class="order-details-list-row">  
                                        <span>Status: </span>
                                        <span><%=  status %></span>
                                    </div>
                                    <div class="order-details-list-row">  
                                        <span>Submitted: </span>
                                        <span><%= new Date(created_at).toLocaleString() %></span>
                                    </div>
                                </div>

                                <% if (status === "unassigned") { %>
                                <button class="assign-order-btn" type="button">
                                    Assign to Me
                                </button>
                                <% } %>

                            </div>
                             <!-- ORDER-ITEMS HEADER-->
                            <div class="order-header-right">Items</div>
                            
                            <!-- ORDER-ITEMS LIST -->
                            <div class="order-items-list">
                            <% items.forEach(({ name, quantity }) => { %>
                                <div class="order-items-list-row">  
                                    <span><%= name %></span>
                                    <!-- <span><i class="fa fa-times"></i></span> -->
                                     <span>x</span>
                                    <span><%= quantity %></span>
                                    <div class="item-submit-wrap">
                                        <button class="item-submit-button" type="button">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                        <span class="submit-message">Submitted!</span>
                                    </div>
                                </div>
                            <% }) %>    
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
            
        </div>
    </main>
    
    <%- include('partials/footer') %> 
    <script src="/js/orders-client.js" defer></script>
</body>
</html>
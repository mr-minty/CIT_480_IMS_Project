<!DOCTYPE html>
<html lang="en">
    <!--EJS vars: %title, %content, %user-->
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Favicon -->
    <link rel="icon" href="img/stockify-favicon-32x32.png" type="image/x-icon">
    
    <!-- Bootstrap call -->
    <%- include("partials/bootstrap-call.ejs") %>
    <%- include("partials/fonts-call.ejs") %> 

    <!-- CSS call -->
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    

    <title><%= title %></title>
</head>

<body>
    <%- include('partials/header') %> 

    <main class="flex-grow-1">
        <!--Welcome Banner-->
        <div id="welcome-banner" class="container mt-2">
            <div class="row justify-start">
                <div class="col-12">
                    <h1>Welcome, <%= user.username %></h1>
                    
                </div>
            </div>
        </div>



        <div class="dashboard-container">
            <a href="/orders" class="dashboard-card">
                <span class="dashboard-card-header">Orders</span>
                <span class="dashboard-card-sub">Fulfill queued orders for pickup or shipment</span>
            </a>
           <a href="/items" class="dashboard-card">
                <span class="dashboard-card-header">Items</span>
                <span class="dashboard-card-sub">Item lookup and inventory management</span>
            </a>
            <a href="/organization" class="dashboard-card">
                <span class="dashboard-card-header">Org</span>
                <span class="dashboard-card-sub">View organization details</span>
            </a>
            <a href="/account" class="dashboard-card">
                <span class="dashboard-card-header">Account</span>
                <span class="dashboard-card-sub">Edit account info and view messages</span>
            </a>
        </div>
        
    </main>
    <%- include('partials/footer') %> 
</body>
</html>